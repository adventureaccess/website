---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RevealObserver from '../components/RevealObserver.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideNavBg?: boolean;
  /** Set true to emit a noindex tag (e.g. thank-you, search results). */
  noindex?: boolean;
  /** Optional extra JSON-LD blocks to append (Article, TouristTrip, Place, etc). */
  schema?: object | object[];
}

const {
  title = 'Adventure Access — Real Adventure Changes You',
  description = 'Custom-built adventure tours across the Himalayas and the Tibetan Plateau. Bhutan, India, Nepal, and Yunnan.',
  ogImage,
  hideNavBg = false,
  noindex = false,
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL('/images/2024/05/Ladakh-hero-image.jpg', Astro.site).toString();

// Organization schema — emitted on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: 'Adventure Access',
  legalName: 'Adventure Access, LLC',
  url: Astro.site?.toString() ?? 'https://www.adventure-access.com/',
  logo: new URL('/favicon.svg', Astro.site).toString(),
  description:
    'Custom adventure tours across the Himalayas and the Tibetan Plateau, with a community of local guides and operators in Bhutan, India, Nepal, and China.',
  areaServed: ['Bhutan', 'India', 'Nepal', 'China', 'Tibet'],
  knowsAbout: [
    'Himalayan trekking',
    'Tibetan Plateau travel',
    'Mountain biking',
    'Cultural immersion travel',
    'Responsible tourism',
  ],
  email: 'info@adventure-access.com',
  sameAs: [
    'https://www.instagram.com/adventureaccesstours/',
    'https://www.facebook.com/adventureaccesstours/',
    'https://www.youtube.com/channel/UCsokw2Ok93KwNdbQKVf9NyA',
    'https://twitter.com/TibetanAdvYeti',
  ],
  memberOf: [
    { '@type': 'Organization', name: 'Adventure Travel Trade Association' },
    { '@type': 'Organization', name: 'CREST — Center for Responsible Travel' },
    { '@type': 'Organization', name: "Tomorrow's Air" },
  ],
};

const extraSchemas: object[] = !schema ? [] : (Array.isArray(schema) ? schema : [schema]);
const allSchemas = [orgSchema, ...extraSchemas];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:site_name" content="Adventure Access" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:site" content="@TibetanAdvYeti" />

    <!-- Structured data -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)}></script>
    ))}

    <!-- Netlify Identity (required for Decap CMS login redirect).
         Loaded ONLY when an invite/recovery/confirmation token is in the URL hash —
         that's the one case where a public page needs the widget. /admin loads its
         own copy. This keeps ~70KB of JS off normal page views. -->
    <script is:inline>
      (function () {
        var hash = window.location.hash;
        if (
          hash.indexOf('invite_token=') === -1 &&
          hash.indexOf('recovery_token=') === -1 &&
          hash.indexOf('confirmation_token=') === -1
        ) return;

        var s = document.createElement('script');
        s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
        s.onload = function () {
          if (!window.netlifyIdentity) return;
          window.netlifyIdentity.on('init', function (user) {
            // Auto-open the modal AFTER the widget has fully initialized
            window.netlifyIdentity.open();
            if (!user) {
              window.netlifyIdentity.on('login', function () {
                document.location.href = '/admin/';
              });
            }
          });
          window.netlifyIdentity.init();
        };
        document.head.appendChild(s);
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <Nav transparent={hideNavBg} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <RevealObserver />
  </body>
</html>
