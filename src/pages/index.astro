---
import Base from '../layouts/Base.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import DestinationScroller from '../components/DestinationScroller.astro';
import Testimonials from '../components/Testimonials.astro';
import destinations from '../data/destinations.json';
import testimonials from '../data/testimonials.json';

const heroTestimonial = testimonials.items.find(t => t.heroQuote);

const heroSlides = [
  { src: '/images/2024/05/Ladakh-hero-image.jpg',           alt: 'Prayer flags above a Ladakh valley in the Indian Himalaya' },
  { src: '/images/2025/11/MTB-Exploration-Photo-3-scaled.jpeg', alt: 'Mountain biker on a high-altitude trail in Zanskar' },
  { src: '/images/2024/05/Bhutan-Hero-Image.jpg',            alt: 'Stone dzong rising above a Bhutanese valley' },
  { src: '/images/2024/05/Nepal-Page-Hero-image-scaled-1.jpeg', alt: 'Snow peaks rising over Nepal' },
  { src: '/images/2024/05/Hero-Image-Lijiang.jpg',           alt: 'Jade Dragon Snow Mountain above Lijiang, Yunnan' },
];
---
<Base hideNavBg={true} title="Adventure Access — Real Adventure Changes You" description="Custom adventure tours through the Himalayas and the Tibetan Plateau. Bhutan, India, Nepal, and Yunnan.">

  <!-- HERO -->
  <section class="relative min-h-[88vh] md:min-h-[100dvh] flex items-end overflow-hidden">
    <HeroSlideshow slides={heroSlides} duration={6500} />
    <div class="relative z-[4] max-w-8xl mx-auto w-full px-6 md:px-14 pb-24 md:pb-32 text-cream">
      <div class="max-w-3xl">
        <div class="eyebrow-cream mb-6 fade-up text-shadow-hero">— Himalayas · Tibetan Plateau</div>
        <h1 class="display text-6xl md:text-8xl mb-6 fade-up-delay-1 text-shadow-hero">
          Real adventure<br><em class="not-italic font-light text-saffron font-display italic">changes</em> you.
        </h1>
        <p class="text-lg md:text-xl text-cream/95 max-w-xl leading-relaxed fade-up-delay-2 text-shadow-hero">
          Once you get to know the people of the Tibetan Plateau and the broader Himalayan region,
          you'll never be the same. Their perspectives sharpen your vision. The challenges of their
          environment invigorate you.
        </p>
      </div>
    </div>

    {/* Scroll cue */}
    <div class="absolute bottom-8 right-6 md:right-14 z-[4] hidden md:flex flex-col items-center text-cream/80 fade-up-delay-3 pointer-events-none">
      <span class="eyebrow-cream mb-3">Scroll</span>
      <span class="block w-px h-10 bg-cream/50"></span>
    </div>
  </section>

  <!-- INTRO (cream) -->
  <section class="py-28 md:py-40 bg-cream">
    <div class="max-w-8xl mx-auto px-6 md:px-14 grid lg:grid-cols-[1fr_1.4fr] gap-16 lg:gap-28 items-center">
      <div class="reveal">
        <div class="eyebrow mb-6">— Our Approach</div>
        <h2 class="display text-5xl md:text-6xl">Travel with a focus on <em class="not-italic font-light text-saffron font-display italic">transformation</em>.</h2>
      </div>
      <div class="text-lg leading-relaxed text-ink-soft space-y-5">
        <p class="reveal" data-delay="100">Towering peaks, deep valleys, and a rich culture appeal to the adventurous. But what else does it mean to experience the Himalayas and the Tibetan Plateau?</p>
        <p class="reveal" data-delay="200">Tibetan communities are culturally rich and extremely hospitable. The places we call home have beckoned adventurous hearts for hundreds of years. Whether you are looking to challenge your physical limits, expound upon your intellectual curiosity, or divulge in local culture and food, each adventurer has a starting point.</p>
        <p class="reveal" data-delay="300">With the right local guidance, you will leave as a transformed traveler.</p>
        <p class="reveal" data-delay="400"><a href="/transformational-travel" class="btn-ghost">Read more on transformation →</a></p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED PHOTO BREAK -->
  <section class="relative h-[60vh] md:h-[75vh] overflow-hidden bg-ink">
    <img
      src="/images/2021/04/trekkers-adventure-access.jpg"
      alt="Trekkers traversing a high Himalayan ridge"
      class="absolute inset-0 w-full h-full object-cover kenburns"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/30 via-ink/10 to-ink/70"></div>
    <div class="relative z-10 h-full max-w-8xl mx-auto px-6 md:px-14 flex flex-col justify-end pb-16 md:pb-24 text-cream">
      <div class="max-w-2xl reveal">
        <div class="eyebrow-cream mb-5 text-shadow-hero">— Where adventure meets local</div>
        <h2 class="display text-5xl md:text-7xl text-shadow-hero">
          Four countries.<br>
          One <em class="not-italic font-light text-saffron font-display italic">community</em>.
        </h2>
      </div>
    </div>
  </section>

  <!-- DESTINATIONS — horizontal scroller (paper) -->
  <section class="bg-paper py-24 md:py-32">
    <div class="max-w-8xl mx-auto px-6 md:px-14 mb-12 md:mb-16">
      <div class="flex flex-wrap justify-between items-end gap-6 reveal">
        <div>
          <div class="eyebrow mb-4">— Destinations</div>
          <h2 class="display text-5xl md:text-6xl">Pick your <em class="not-italic font-light text-saffron font-display italic">place</em>.</h2>
        </div>
        <a href="/transformational-travel" class="btn-ghost">View all destinations →</a>
      </div>
    </div>
    <div class="reveal">
      <DestinationScroller destinations={destinations} />
    </div>
  </section>

  <!-- TRANSFORMATIONAL TRAVEL — dark section -->
  <section class="bg-ink text-cream py-28 md:py-40 relative overflow-hidden">
    {/* Decorative oversized type */}
    <div class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/4 select-none pointer-events-none opacity-[0.04] overflow-hidden hidden md:block" aria-hidden="true">
      <span class="font-display font-light text-[24vw] uppercase whitespace-nowrap">Himalaya</span>
    </div>
    <div class="relative z-10 max-w-8xl mx-auto px-6 md:px-14 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="reveal-left">
        <div class="eyebrow-cream mb-6">— Why we do this</div>
        <h2 class="display text-5xl md:text-7xl mb-8">
          The trip ends.<br>
          The <em class="not-italic font-light text-saffron font-display italic">change</em> doesn't.
        </h2>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-cream/85 reveal-right">
        <p>Once you've shared butter tea in a Ladakhi kitchen, navigated a Bhutanese mountain pass with a local guide, or watched first light strike a Nepali peak you trekked for days to reach — your sense of what's possible shifts.</p>
        <p>That's not a marketing line. That's the point of the whole thing.</p>
        <p class="pt-2"><a href="/transformational-travel" class="btn-ghost-cream">Read our manifesto →</a></p>
      </div>
    </div>
  </section>

  <!-- OUR LOCAL (alternating photo + text, cream) -->
  <section class="bg-cream py-24 md:py-36">
    <div class="max-w-8xl mx-auto px-6 md:px-14 grid lg:grid-cols-[1fr_1.2fr] gap-16 lg:gap-24 items-center">
      <div class="reveal-left aspect-[4/5] overflow-hidden">
        <img
          src="/images/2023/06/About-Us-General-2-scaled.jpg"
          alt="Adventure Access team and local partners"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="reveal-right">
        <div class="eyebrow mb-6">— Our Local</div>
        <h2 class="display text-5xl md:text-6xl mb-8">Your adventure is <em class="not-italic font-light text-saffron font-display italic">our local</em>.</h2>
        <div class="text-lg leading-relaxed text-ink-soft space-y-5">
          <p>Our founders embraced Tibet decades ago. Our family of operators, guides, and hospitality experts has spread throughout Bhutan, China, India and Nepal. Our mix of American roots and local families creates a rare bridge — one that gives you unrivaled access to the true Himalayan experience.</p>
          <p>We're eager to help you discover the breath-taking scenery and unique peoples across the region. We're excited for you to discover how your experience will transform, enlighten and inspire.</p>
        </div>
        <a href="/about" class="btn mt-10">Meet the Team</a>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- TESTIMONIAL ON PHOTO -->
  <section class="relative py-28 md:py-40 overflow-hidden">
    <img
      src="/images/2021/04/thangkha-adventure-access.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-ink/75"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-14 text-center text-cream reveal">
      <div class="eyebrow-cream mb-8">— From a traveler</div>
      <blockquote class="font-display font-light italic text-3xl md:text-5xl leading-tight tracking-tight mb-8 text-shadow-hero">
        "{heroTestimonial?.quote}"
      </blockquote>
      <cite class="eyebrow-cream not-italic">— {heroTestimonial?.name} · {heroTestimonial?.location}</cite>
    </div>
  </section>

  <!-- FEATURED ARTICLE (paper) -->
  <section class="bg-paper py-28 md:py-36">
    <div class="max-w-8xl mx-auto px-6 md:px-14">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <a href="/blog/hidden-mountain-bike-routes-in-ladakh" class="reveal-left group block aspect-[4/3] overflow-hidden bg-cream">
          <img
            src="/images/2025/11/MTB-Exploration-Photo-3-scaled.jpeg"
            alt="Mountain biker descending in the Western Himalaya"
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-[1200ms] group-hover:scale-105"
          />
        </a>
        <div class="reveal-right">
          <div class="eyebrow mb-5">— From the Journal</div>
          <h2 class="display text-4xl md:text-5xl mb-5">Ride the Himalayas: Zanskar's hidden mountain bike routes.</h2>
          <p class="text-lg leading-relaxed text-ink-soft mb-8">
            The air thins as you approach the crest of Kyupa La. At 4,400 meters,
            every breath is earned. Below you, the trail unravels like a ribbon across
            scree slopes and ridgelines, plunging toward a valley where life hasn't
            changed in centuries.
          </p>
          <a href="/blog/hidden-mountain-bike-routes-in-ladakh" class="btn-ghost">Read the article →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PLAN A TRIP CTA ON DARK PHOTO -->
  <section id="plan" class="relative overflow-hidden">
    <img
      src="/images/2024/05/Ladakh-hero-image.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ink/90 via-ink/75 to-ink/55"></div>
    <div class="relative z-10 max-w-8xl mx-auto px-6 md:px-14 py-24 md:py-36 text-cream">
      <div class="max-w-2xl reveal">
        <div class="eyebrow-cream mb-6">— Plan a trip</div>
        <h2 class="display text-5xl md:text-7xl mb-8 text-shadow-hero">
          Let's get you on the <em class="not-italic font-light text-saffron font-display italic">mountain</em>.
        </h2>
        <p class="text-lg md:text-xl text-cream/90 leading-relaxed mb-10 text-shadow-hero">
          Tell us where you'd like to go and what kind of adventure you're after.
          Our team will design something custom.
        </p>
        <a href="mailto:info@adventure-access.com" class="btn-cream">Start the conversation</a>
      </div>
    </div>
  </section>

</Base>
