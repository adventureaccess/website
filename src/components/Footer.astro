---
const year = new Date().getFullYear();
---
<footer id="contact" class="bg-ink text-cream">
  <div class="max-w-8xl mx-auto px-6 md:px-14 py-24 md:py-32">
    <div class="grid lg:grid-cols-[1.3fr_1fr] gap-16 lg:gap-32 mb-20">
      <div>
        <div class="eyebrow !text-saffron mb-6">— Start a Conversation</div>
        <h2 class="display text-5xl md:text-6xl mb-6">Plan a journey<br><em class="not-italic font-light text-saffron font-display italic">with us</em>.</h2>
        <p class="text-cream/80 text-lg leading-relaxed max-w-lg mb-8">
          Tell us where your curiosity lives — the mountains, the monasteries, the long roads.
          One of our travel specialists will reply within 24 hours.
        </p>
        <a href="mailto:info@adventure-access.com" class="inline-block text-2xl font-display text-saffron border-b border-saffron/40 pb-1 hover:border-saffron transition-colors">
          info@adventure-access.com →
        </a>
      </div>

      <form
        name="inquiry"
        method="POST"
        action="/thank-you/"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-6"
      >
        {/* Netlify form detection requires this hidden input on JS-rendered forms */}
        <input type="hidden" name="form-name" value="inquiry" />
        {/* Honeypot — bots fill this in, humans don't see it */}
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <div>
          <label class="block eyebrow !text-cream/60 mb-2" for="name">Your name</label>
          <input id="name" name="name" required type="text" class="w-full bg-transparent border-b border-cream/30 py-2 text-cream placeholder:text-cream/40 focus:outline-none focus:border-saffron transition-colors" placeholder="" />
        </div>
        <div>
          <label class="block eyebrow !text-cream/60 mb-2" for="email">Email</label>
          <input id="email" name="email" required type="email" class="w-full bg-transparent border-b border-cream/30 py-2 text-cream placeholder:text-cream/40 focus:outline-none focus:border-saffron transition-colors" placeholder="" />
        </div>
        <div>
          <label class="block eyebrow !text-cream/60 mb-2" for="interest">What pulls you here</label>
          <select id="interest" name="interest" class="w-full bg-transparent border-b border-cream/30 py-2 text-cream focus:outline-none focus:border-saffron">
            <option class="text-ink">Trekking / Hiking</option>
            <option class="text-ink">Mountain Biking</option>
            <option class="text-ink">Cultural Tour</option>
            <option class="text-ink">Overland Experience</option>
            <option class="text-ink">Not sure yet</option>
          </select>
        </div>
        <div>
          <label class="block eyebrow !text-cream/60 mb-2" for="region">Region</label>
          <select id="region" name="region" class="w-full bg-transparent border-b border-cream/30 py-2 text-cream focus:outline-none focus:border-saffron">
            <option class="text-ink">Ladakh, India</option>
            <option class="text-ink">Nepal</option>
            <option class="text-ink">Bhutan</option>
            <option class="text-ink">Yunnan, China</option>
            <option class="text-ink">Open to suggestions</option>
          </select>
        </div>
        <div>
          <label class="block eyebrow !text-cream/60 mb-2" for="message">A few words about your trip <span class="text-cream/40 normal-case tracking-normal">(optional)</span></label>
          <textarea id="message" name="message" rows="4" class="w-full bg-transparent border-b border-cream/30 py-2 text-cream placeholder:text-cream/40 focus:outline-none focus:border-saffron transition-colors resize-none" placeholder=""></textarea>
        </div>
        <button type="submit" class="btn !bg-saffron hover:!bg-saffron-dark">Send Inquiry</button>
      </form>
    </div>

    <!-- Trustpilot trust badge -->
    <div class="border-t border-cream/15 pt-10 mb-10 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <span class="eyebrow !text-cream/50">— Verified reviews</span>
      <div
        class="trustpilot-widget"
        data-locale="en-US"
        data-template-id="5419b6a8b0d04a076446a9ad"
        data-businessunit-id="642447cd2e0c1ea51782db6e"
        data-style-height="24px"
        data-style-width="260px"
        data-theme="dark"
      >
        <a href="https://www.trustpilot.com/review/adventure-access.com" target="_blank" rel="noopener" class="text-saffron hover:underline text-sm">Read our reviews on Trustpilot →</a>
      </div>
    </div>

    <div class="border-t border-cream/15 pt-10 grid md:grid-cols-3 gap-8 text-sm text-cream/70">
      <div>
        <div class="font-display text-2xl text-cream mb-2">Adventure · Access</div>
        <p>Custom adventure tours throughout the Himalayas and the Tibetan Plateau.</p>
      </div>
      <div>
        <div class="eyebrow !text-cream/50 mb-3">— Memberships</div>
        <ul class="space-y-1.5">
          <li><a href="https://www.adventuretravel.biz" target="_blank" rel="noopener" class="hover:text-saffron">Adventure Travel Trade Association</a></li>
          <li><a href="https://www.responsibletravel.org/" target="_blank" rel="noopener" class="hover:text-saffron">CREST</a></li>
          <li><a href="https://www.tomorrowsair.com/" target="_blank" rel="noopener" class="hover:text-saffron">Tomorrow's Air</a></li>
          <li><a href="https://www.tripadvisor.com.sg/Attraction_Review-g297463-d7080996-Reviews-Adventure_Access-Chengdu_Sichuan.html" target="_blank" rel="noopener" class="hover:text-saffron">Tripadvisor</a></li>
        </ul>
      </div>
      <div>
        <div class="eyebrow !text-cream/50 mb-3">— Follow</div>
        <ul class="space-y-1.5">
          <li><a href="https://www.instagram.com/adventureaccesstours/" target="_blank" rel="noopener" class="hover:text-saffron">Instagram</a></li>
          <li><a href="https://www.facebook.com/adventureaccesstours/" target="_blank" rel="noopener" class="hover:text-saffron">Facebook</a></li>
          <li><a href="https://www.youtube.com/channel/UCsokw2Ok93KwNdbQKVf9NyA" target="_blank" rel="noopener" class="hover:text-saffron">YouTube</a></li>
          <li><a href="https://twitter.com/TibetanAdvYeti" target="_blank" rel="noopener" class="hover:text-saffron">X / Twitter</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-cream/15 pt-8 mt-12 flex flex-wrap justify-between gap-4 text-xs text-cream/50">
      <p>© {year} Adventure Access, LLC · All Rights Reserved</p>
      <div class="flex gap-6">
        <a href="/privacy-cookie-policy" class="hover:text-saffron">Privacy & Cookies</a>
        <a href="/payment-terms-cancellation-policy" class="hover:text-saffron">Payment Terms</a>
      </div>
    </div>
  </div>
</footer>
